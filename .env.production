# Loaded automatically by `vite build` (mode=production).
# The stream URL is baked into the bundle because live.personals3.tech is
# a static host with no proxy. A real environment variable with the same
# name still overrides this (Vite gives process env precedence), so other
# deploy targets can rebake without touching the repo.
VITE_LIVE_URL=https://personals3.tech/api/live
